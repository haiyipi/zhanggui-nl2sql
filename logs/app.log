WITH CustomerPurchases AS (
    SELECT 
        fo.customer_id,
        dp.category
    FROM 
        fact_order fo
    JOIN 
        dim_product dp ON fo.product_id = dp.product_id
    WHERE 
        dp.category IN ('手机数码', '家用电器')
),
CustomerCategoryCounts AS (
    SELECT 
        cp.customer_id,
        COUNT(DISTINCT CASE WHEN cp.category = '手机数码' THEN 1 END) AS mobile_count,
        COUNT(DISTINCT CASE WHEN cp.category = '家用电器' THEN 1 END) AS appliance_count
    FROM 
        CustomerPurchases cp
    GROUP BY 
        cp.customer_id
    HAVING 
        mobile_count > 0 AND appliance_count > 0
)
SELECT 
    dc.customer_name,
    dc.member_level
FROM 
    dim_customer dc
JOIN 
    CustomerCategoryCounts ccc ON dc.customer_id = ccc.customer_id;
```
