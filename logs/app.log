    SELECT
        cs.customer_id,
        cs.total_spent,
        cs.total_orders,
        cs.avg_order_amount,
        cs.latest_date_id,
        ROW_NUMBER() OVER (ORDER BY cs.total_spent DESC) AS rn
    FROM CustomerSpending cs
)
SELECT
    dc.customer_name,
    rc.total_spent AS consumption_total,
    rc.avg_order_amount,
    rc.total_orders,
    STR_TO_DATE(CAST(rc.latest_date_id AS CHAR), '%Y%m%d') AS latest_purchase_date
FROM RankedCustomers rc
JOIN dim_customer dc ON rc.customer_id = dc.customer_id
WHERE rc.rn <= 5
ORDER BY rc.total_spent DESC;
